rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for cleaner, reusable rule logic.

    // Is the request coming from a logged-in user?
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Fast path: check the custom claim set by the setAdminClaim Cloud Function.
    // This avoids an extra Firestore document read on every rule evaluation.
    function isAdminByToken() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    // Full admin check: token claim first (fast), then Firestore doc (fallback
    // for admins who have not yet called setAdminClaim to refresh their token).
    function isAdmin() {
      return isAdminByToken()
          || (isSignedIn()
              && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Does the logged-in user's UID match the given userId?
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. USERS COLLECTION
    // Stores user profiles for both admins and tenants.
    match /users/{userId} {
      // You can read your own profile. Admins can read any profile.
      allow read: if isOwner(userId) || isAdmin();

      // Self-registration is restricted to tenant role only.
      // Required fields must be present and of the correct type.
      allow create: if (isOwner(userId)
                        && request.resource.data.role == 'tenant'
                        && request.resource.data.name is string
                        && request.resource.data.email is string
                        && request.resource.data.houseId is string)
                    || isAdmin();

      // Tenants can update their own profile but only the safe display fields.
      // They cannot change their role, houseId, rentAmount, or balance.
      allow update: if isAdmin()
                    || (isOwner(userId)
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.diff(resource.data)
                              .affectedKeys()
                              .hasOnly(['name', 'phone', 'profilePicture']));

      // Only admins can delete user profiles.
      allow delete: if isAdmin();
    }

    // 2. HOUSES COLLECTION
    // Stores rental property information.
    match /houses/{houseId} {
      // Any logged-in user can read houses (tenants need this during registration).
      allow read: if isSignedIn();

      // Only admins can create or delete houses.
      allow create, delete: if isAdmin();

      // Only admins can update house details.
      // Tenant self-registration into a house is handled by the admin
      // creating the tenant profile, or via a controlled registration flow
      // where the security of the update is validated server-side.
      allow update: if isAdmin();
    }

    // 3. PAYMENTS COLLECTION
    // Tracks rent payments submitted by tenants.
    match /payments/{paymentId} {
      // Tenants see only their own payments. Admins see all.
      allow read: if isAdmin() || (isSignedIn() && resource.data.tenantId == request.auth.uid);

      // Tenants can submit payments, but only for themselves,
      // and the status must start as "pending" with a positive amount.
      allow create: if isSignedIn()
                    && request.resource.data.tenantId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0;

      // Only admins can update (approve/reject) or delete payments.
      allow update, delete: if isAdmin();
    }

    // 4. ANNOUNCEMENTS COLLECTION
    // Both admins and tenants can post announcements.
    match /announcements/{announcementId} {
      // Any logged-in user can read announcements.
      allow read: if isSignedIn();

      // Users can create announcements but must set createdBy to their own UID
      // and provide title and message as non-empty strings.
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.message is string;

      // Only admins or the original creator can edit or delete.
      // On update, the createdBy field cannot be changed.
      allow update, delete: if isAdmin()
                            || (isSignedIn()
                                && resource.data.createdBy == request.auth.uid
                                && request.resource.data.createdBy == resource.data.createdBy);
    }

    // 5. MAINTENANCE REQUESTS COLLECTION
    // Tenants submit requests; admins manage them.
    match /maintenanceRequests/{requestId} {
      // Tenants can read their own requests. Admins can read all.
      allow read: if isAdmin() || (isSignedIn() && resource.data.tenantUid == request.auth.uid);

      // Tenants can create requests for themselves only,
      // and the status must start as "pending".
      allow create: if isSignedIn()
                    && request.resource.data.tenantUid == request.auth.uid
                    && request.resource.data.status == 'pending';

      // Only admins can update or delete requests.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 6. ANONYMOUS MESSAGES COLLECTION
    // Tenants send anonymous messages to admin.
    match /anonymousMessages/{messageId} {
      // Only admins can read anonymous messages.
      allow read: if isAdmin();

      // Any signed-in user can create a message (must use their own UID).
      // The message field must be a non-empty string to prevent inbox flooding.
      allow create: if isSignedIn()
                    && request.resource.data.tenantUid == request.auth.uid
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0;

      // Nobody can update or delete anonymous messages.
      allow update, delete: if false;
    }

    // 7. INVOICES COLLECTION (reserved for future use)
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.tenantId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // 8. SETTINGS COLLECTION
    // System-wide property and billing configuration.
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 9. SERVICE DIRECTORY COLLECTION
    // Directory of vetted tradespeople and specialists.
    match /serviceDirectory/{providerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 10. PROPERTY GALLERY COLLECTION
    // Photos and images of the rental property.
    match /propertyGallery/{photoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

  }
}